{
  "manifest_version": 3,
  "name": "Readmd - Immersive Reader",
  "version": "1.0.0",
  "description": "Immersive reading experience for Markdown-style web documents.",
  "icons": {
    "16": "assets/icons/icon16.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  },
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Readmd Settings",
    "default_icon": {
      "16": "assets/icons/icon16.png",
      "48": "assets/icons/icon48.png",
      "128": "assets/icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "css": ["content_scripts/content.css"],
      "js": ["content_scripts/Readability.js", "content_scripts/content.js"]
    }
  ]
}
